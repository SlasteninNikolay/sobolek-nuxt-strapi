HOST=0.0.0.0
PORT=1337
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# === SMTP (email provider: nodemailer) ===
# REG.RU обычно предлагает:
# - 587 (STARTTLS) -> SMTP_SECURE=false, SMTP_REQUIRE_TLS=true
# - 465 (SMTPS/SSL) -> SMTP_SECURE=true, SMTP_REQUIRE_TLS=false
SMTP_HOST=mail.hosting.reg.ru
SMTP_PORT=465
SMTP_USERNAME=no-reply@example.ru
SMTP_PASSWORD=change_me
SMTP_SECURE=true
SMTP_REQUIRE_TLS=false
SMTP_IGNORE_TLS=false
SMTP_TLS_REJECT_UNAUTHORIZED=true

SMTP_DEFAULT_FROM=no-reply@example.ru
SMTP_DEFAULT_REPLY_TO=no-reply@example.ru
SMTP_TO_ADMIN=admin@example.ru

SEND_EMAILS=true
EMAIL_TIMEOUT=30000
EMAIL_DEBUG=false
EMAIL_LOGGER=true
